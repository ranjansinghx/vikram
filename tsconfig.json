{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "none",
    "ignoreDeprecations": "6.0",
    "outDir": "js",
    "rootDir": "ts",
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "removeComments": false,
    "noEmitOnError": false,
    "isolatedModules": false
  },
  "include": ["ts/**/*.ts"]
}
